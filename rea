# ── MÉTRIQUES SEUILS (infrastructure) ─────────────────────
# RAM minimale requise en GB
SEUIL_RAM_MIN_GB=8
# Espace disque minimal requis en GB
SEUIL_DISQUE_MIN_GB=20
# CPU usage maximum accepté en %
SEUIL_CPU_MAX_PERCENT=80
# Fragmentation index : seuil REORGANIZE (%)
SEUIL_FRAGMENTATION_REORGANIZE=10
# Fragmentation index : seuil REBUILD (%)
